{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/website/(.*)",
      "destination": "/website/$1"
    },
    {
      "source": "/downloads/raizen.zip",
      "destination": "https://github.com/paras2l/the-paxion/releases/latest/download/raizen.zip"
    },
    {
      "source": "/downloads/raizen.apk",
      "destination": "https://github.com/paras2l/the-paxion/releases/latest/download/raizen.apk"
    },
    {
      "source": "/downloads/raizen-setup.exe",
      "destination": "https://github.com/paras2l/the-paxion/releases/latest/download/raizen-setup.exe"
    },
    {
      "source": "/((?!api/|website/|downloads/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
