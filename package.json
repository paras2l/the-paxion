{
  "name": "the-raizen",
  "private": true,
  "version": "0.23.6",
  "description": "The Raizen - Personal AI Desktop Assistant",
  "author": "Paro the Chief",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "desktop": "npm run build && electron .",
    "icon:win": "node scripts/generate-app-icon.mjs",
    "dist:win": "npm run icon:win && npm run build && electron-builder --win nsis -p always",
    "lint": "eslint .",
    "test": "node --test electron/readiness-utils.test.cjs electron/readiness-integration.test.cjs electron/compliance-engine.test.cjs electron/domain-engines.test.cjs electron/advanced-systems.test.cjs",
    "preview": "vite preview",
    "deploy": "node scripts/deploy.mjs",
    "publish-builds": "node scripts/publish.mjs"
  },
  "build": {
    "appId": "ai.raizen.desktop",
    "productName": "The Raizen",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/raizen.ico",
      "artifactName": "raizen.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/raizen.ico",
      "uninstallerIcon": "public/raizen.ico",
      "installerHeaderIcon": "public/raizen.ico",
      "artifactName": "raizen-setup.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "paras2l",
      "repo": "the-paxion",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.8.3",
    "pdf-parse": "^2.4.5",
    "puppeteer-core": "^24.40.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.1"
  }
}
